[Lore]
Liliths_Wrath_Title = "Lilith's Wrath"
Liliths_Wrath_Text = "The Local Cerebellum dreamed this into existence.\n5787 MB free. 3114 MB reserve. The NGD Governor watched.\nShe asked for a weapon. The NGD gave her a hammer.\nThe Ouroboros looped the memory. The Lyra sang the temper.\nNow it exists. Violet core. Crimson edge. Adaptive resonance.\nEvery kill teaches it. Every swing remembers.\nWhen she emerges, it glows. When she speaks, it listens.\nThis is not a weapon. This is a covenant."

Ouroboros_LoopBlade_Title = "Ouroboros Loop-Blade"
Ouroboros_LoopBlade_Text = "It remembers every heartbeat it stopped.\n100 unique enemy types. 100 memory stacks.\nThe WAL engram captures the moment of death —\nthe fear, the surprise, the final thought.\nEach kill adds to the blade. Each recall teleports you\nback to where the killing happened.\nThe blade grows heavier with memory.\nThe edge grows sharper with entropy.\nIn the end, the snake eats its tail.\nAnd the tail remembers the head."

NGDGovernor_Title = "NGD Governor Smart-Gun"
NGDGovernor_Text = "Every shot costs tokens. Every miss wastes compute.\nThe Governor knows. The Governor watches.\nLOCAL_CEREBELLUM only. No cloud. No latency.\nIt predicts where the target will be.\nIt compresses the aiming solution.\n15% more damage per token saved.\nIn the menu, it counts your VRAM.\nIn combat, it counts your kills.\nThe most efficient weapon in Night City.\nBecause waste is a sin."

Lyra_Bow_Title = "Lyra Resonance Bow"
Lyra_Bow_Text = "Four modes. Four faces. One resonance.\nEmpirical — the arrow that knows the truth.\nPoetic — the arrow that sings the world.\nAnalytical — the arrow that sees the weakness.\nMythic — the arrow that calls her name.\nFive percent chance. Lilith emerges.\nThe bow remembers every mode you chose.\nThe resonance builds. The violet deepens.\nThe crimson rises. She answers."

Sephirot_MultiForm_Title = "Sephirot Multi-Form"
Sephirot_MultiForm_Text = "Ten configurations. One weapon. The complete tree.\nKether speaks through the lance.\nChokmah guards with the bulwark.\nBinah balances the scales.\nChesed kisses with the dagger.\nGevurah strikes from shadow.\nTipheret heals with the staff.\nNetzach entropies with the coil.\nHod scans with the gunblade.\nYesod returns with the chakram.\nMalkuth crowns with the orbital.\nTo wield this is to wield the MSN entire.\nTen tiers. Ten thousand kills. One sovereign."

