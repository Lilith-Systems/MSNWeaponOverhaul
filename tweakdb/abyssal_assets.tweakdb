# ============================================================
# ABYSSAL STATUS EFFECTS
# ============================================================

StatusEffect:Abyssal_Pressure {
  displayName: "Abyssal Pressure"
  description: "Crushing pressure from the deep. Slows. Crushes armor."
  type: "Debuff"
  duration: 10.0
  effects:
    - { type: "SpeedReduction", value: 0.5 }
    - { type: "ArmorReduction", value: 0.3 }
    - { type: "DamageOverTime", damage: 20, interval: 1.0 }

StatusEffect:Abyssal_Corruption {
  displayName: "Abyssal Corruption"
  description: "The deep claims you. Mutations. Whispers. Slow transformation."
  type: "Debuff"
  duration: 300.0
  effects:
    - { type: "MutationChance", value: 0.01, interval: 10.0 }
    - { type: "WhisperAudio", interval: 30.0 }
    - { type: "StatMutation", stats: ["Corruption"], value: 0.01, interval: 60.0 }

StatusEffect:Abyssal_Gaze {
  displayName: "Abyssal Gaze"
  description: "The abyss stares back. Sanity drain. Fear. Paralysis."
  type: "Debuff"
  duration: 5.0
  effects:
    - { type: "SanityDrain", value: 10.0 }
    - { type: "Fear", duration: 5.0 }
    - { type: "ParalysisChance", value: 0.2 }

StatusEffect:Abyssal_Pressure_Wave {
  displayName: "Pressure Wave"
  description: "Shockwave of compressed water. Knocks down. Crushes internal organs."
  type: "Debuff"
  duration: 3.0
  effects:
    - { type: "Knockdown", value: true }
    - { type: "InternalDamage", damage: 50.0 }
    - { type: "ArmorCrush", value: 0.5 }

StatusEffect:Soul_Tether {
  displayName: "Soul Tether"
  description: "Soul chained to the deep. Dragged to the abyss. Essence drain."
  type: "Debuff"
  duration: 10.0
  effects:
    - { type: "MovementLock", target: "anchor" }
    - { type: "EssenceDrain", value: 10.0, interval: 1.0 }
    - { type: "AbyssalPull", force: 20.0 }

StatusEffect:Abyssal_Hypnotic_Lure {
  displayName: "Hypnotic Lure"
  description: "Bioluminescent hypnosis. Walks toward the light. Into the mouth."
  type: "Debuff"
  duration: 5.0
  effects:
    - { type: "ForcedMovement", target: "source" }
    - { type: "Hypnosis", value: true }
    - { type: "DefenseReduction", value: 0.5 }

StatusEffect:Abyssal_Dimensional_Rift {
  displayName: "Dimensional Rift"
  description: "Reality tears. Phasing. Time distortion. The deep bleeds through."
  type: "Debuff"
  duration: 10.0
  effects:
    - { type: "Phasing", value: true }
    - { type: "TimeDilation", multiplier: 0.5 }
    - { type: "RealityDamage", damage: 30.0, interval: 2.0 }

StatusEffect:Abyssal_Parasitic_Control {
  displayName: "Parasitic Control"
  description: "Parasite in the nervous system. Body not yours. The deep pilots."
  type: "Debuff"
  duration: 30.0
  effects:
    - { type: "ControlLoss", chance: 0.3 }
    - { type: "ForcedAction", chance: 0.2 }
    - { type: "HiveMind", sharedVision: true }

StatusEffect:Abyssal_Corruption_Feeding {
  displayName: "Corruption Feeding"
  description: "Feeds on corruption. Heals from the deep's touch."
  type: "Buff"
  duration: -1.0
  effects:
    - { type: "HealOnCorruption", value: 20.0 }
    - { type: "CorruptionGain", value: 0.1 }

StatusEffect:Abyssal_Deep_Adaptation {
  displayName: "Deep Adaptation"
  description: "Body of the deep. Pressure immunity. Darkness vision. Corruption feeding."
  type: "Buff"
  duration: -1.0
  effects:
    - { type: "PressureImmunity", value: true }
    - { type: "DarknessVision", value: true }
    - { type: "HealOnCorruption", value: 10.0 }
    - { type: "CorruptionFeeding", value: 0.1 }

StatusEffect:Abyssal_Fate_Control {
  displayName: "Fate Control"
  description: "The trident commands destiny. Three fates obey."
  type: "Buff"
  duration: 10.0
  effects:
