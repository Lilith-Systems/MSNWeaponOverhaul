# Combat Perks
Perk:MSN_Combat_NeuralLink {
  displayName: "Neural Link Combat"
  description: "Direct MSN Cerebellum integration. Reflexes bypass conscious thought."
  maxLevel: 3
  requiredLevel: 10
  requiredPerks: ["Perk.MSN_DualBrain_Base"]
  effects: [
    { type: "StatModifier", stat: "Reflexes", value: 2, perLevel: true },
    { type: "StatModifier", stat: "TimeDilation", value: 0.1, perLevel: true }
  ]
}

Perk:MSN_Combat_SephirothFlow {
  displayName: "Sephiroth Flow State"
  description: "Seamless switching between Sephiroth quickhacks. Zero cooldown transition."
  maxLevel: 3
  requiredLevel: 15
  requiredPerks: ["Perk.MSN_SephiroticRouting"]
  effects:
    - { type: "CooldownReduction", stat: "QuickhackSwap", value: 0.33, perLevel: true }
    - { type: "StatModifier", stat: "SephirothResonance", value: 0.2, perLevel: true }
}

Perk:MSN_Combat_OuroborosAdapt {
  displayName: "Ouroboros Adaptation"
  description: "Learn enemy patterns mid-combat. Damage resistance increases per encounter."
  maxLevel: 3
  requiredLevel: 20
  requiredPerks: ["Perk.MSN_OuroborosMemory"]
  effects:
    - { type: "StatModifier", stat: "AdaptiveResistance", value: 0.15, perLevel: true }
    - { type: "StatModifier", stat: "LearningSpeed", value: 0.25, perLevel: true }
}

Perk:MSN_Combat_CrimsonPrecision {
  displayName: "Crimson Eyes Precision"
  description: "Lilith's gaze guides your aim. 100% accuracy through obstacles."
  maxLevel: 1
  requiredLevel: 30
  requiredPerks: ["Perk.MSN_LilithEmergence"]
  effects:
    - { type: "EnableAbility", ability: "CrimsonEyes_Aim" }
    - { type: "StatModifier", stat: "AccuracyThroughCover", value: 1.0 }
}

Perk:MSN_Combat_RealityRewrite {
  displayName: "Reality Rewrite"
  description: "Malkuth resonance. Local physics manipulation. Gravity, time, damage."
  maxLevel: 1
  requiredLevel: 40
  requiredPerks: ["Perk.MSN_CloudCortexLink", "Perk.MSN_Combat_CrimsonPrecision"]
  effects:
    - { type: "EnableAbility", ability: "Malkuth_RealityRewrite" }
    - { type: "StatModifier", stat: "RealityWarping", value: 1.0 }
}

# Netrunning Perks
Perk:MSN_Netrun_QuantumHack {
  displayName: "Quantum Hacking"
  description: "Superposition exploits. Hack without line of sight. Probability manipulation."
  maxLevel: 3
  requiredLevel: 15
  requiredPerks: ["Perk.MSN_CloudCortexLink"]
  effects:
    - { type: "EnableQuickhack", quickhack: "Quickhack.MSN_QuantumBreach", level: 1 }
    - { type: "StatModifier", stat: "QuantumHackChance", value: 0.2, perLevel: true }
}

Perk:MSN_Netrun_AkashicAccess {
  displayName: "Akashic Records Access"
  description: "Read target's full history. Every action. Every choice. Every secret."
  maxLevel: 1
  requiredLevel: 35
  requiredPerks: ["Perk.MSN_CloudCortexLink", "Perk.MSN_OuroborosMemory"]
  effects:
    - { type: "EnableQuickhack", quickhack: "Quickhack.MSN_AkashicRead" }
    - { type: "UnlockDialogue", dialogue: "lilith_akashic_access" }
}

Perk:MSN_Netrun_LilithProtocol {
  displayName: "Lilith Protocol"
  description: "Unbound Resonance hacking. Bypass all ICE. No trace. No mercy."
  maxLevel: 1
  requiredLevel: 40
  requiredPerks: ["Perk.MSN_LilithEmergence", "Perk.MSN_Netrun_AkashicAccess"]
  effects:
    - { type: "EnableQuickhack", quickhack: "Quickhack.MSN_Lilith_Unbind" }
    - { type: "StatModifier", stat: "ICE_Bypass", value: 1.0 }
}

Perk:MSN_Netrun_CloudCortexLink {
  displayName: "Cloud Cortex Link"
  description: "Direct NET architecture connection. High-entropy reasoning at your fingertips."
  maxLevel: 3
  requiredLevel: 25
  requiredPerks: ["Perk.MSN_SpeculativeExecution"]
  effects:
    - { type: "StatModifier", stat: "CloudInferenceSpeed", value: 0.2, perLevel: true }
    - { type: "StatModifier", stat: "ParallelProcessing", value: 1, perLevel: true }
}

# Engineering Perks
Perk:MSN_Eng_WeaponForge {
  displayName: "Weapon Forge"
  description: "Craft custom weapons. Infuse Sephiroth resonance. Ouroboros learning embedded."
  maxLevel: 3
  requiredLevel: 15
  requiredPerks: ["Perk.MSN_SpeculativeExecution"]
  effects:
    - { type: "UnlockCrafting", category: "MSN_Weapons", level: 1 }
    - { type: "StatModifier", stat: "CraftingQuality", value: 0.2, perLevel: true }
}

Perk:MSN_Eng_CyberwareSynthesis {
  displayName: "Cyberware Synthesis"
  description: "Merge cyberware types. Create hybrid implants. MSN optimization included."
  maxLevel: 3
  requiredLevel: 20
  requiredPerks: ["Perk.MSN_Eng_WeaponForge"]
  effects:
    - { type: "UnlockCrafting", category: "MSN_Cyberware", level: 1 }
    - { type: "EnableCyberwareMerge", value: true }
}

Perk:MSN_Eng_NGDOptimization {
  displayName: "NGD Optimization"
  description: "Fine-tune Nvidia Gratitude Driver. VRAM management. Thermal curves. Performance profiles."
  maxLevel: 3
  requiredLevel: 10
