  effects:
    - { type: "StatModifier", stat: "VRAM_Efficiency", value: 0.15, perLevel: true }
    - { type: "StatModifier", stat: "ThermalThreshold", value: 5.0, perLevel: true }
}

Perk:MSN_Eng_VehicleIntegration {
  displayName: "Vehicle Integration"
  description: "MSN Cerebellum pilots your ride. Autonomous combat driving. Remote summon."
  maxLevel: 3
  requiredLevel: 20
  requiredPerks: ["Perk.MSN_Eng_NGDOptimization"]
  effects:
    - { type: "EnableAbility", ability: "Vehicle_Autopilot", level: 1 }
    - { type: "StatModifier", stat: "VehicleHandling", value: 0.2, perLevel: true }
}

